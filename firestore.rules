rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Real account (email/password or Google) — not anonymous
    function hasEmail() {
      return signedIn() && request.auth.token.email != null;
    }

    // To further restrict staff vs customers:
    // Add custom claim {staff: true} via Admin SDK and use
    // request.auth.token.staff == true instead of hasEmail() for staff rules.

    match /products/{productId} {
      allow read: if signedIn();
      allow create, update, delete: if hasEmail();
    }

    match /productCategories/{categoryId} {
      allow read: if signedIn();
      allow create, update, delete: if hasEmail();
    }

    match /orders/{orderId} {
      // Market customers: create their own order only
      allow create: if hasEmail()
        && request.resource.data.customerUid == request.auth.uid;
      // Market customers: read their own orders
      allow read: if hasEmail()
        && resource.data.customerUid == request.auth.uid;
      // Staff (Flutter): full access — covers the above two rules as well
      allow read, create, update, delete: if hasEmail();
    }

    match /invoices/{invoiceId} {
      // Market customers: read invoice linked to their own order
      allow read: if hasEmail()
        && get(/databases/$(database)/documents/orders/$(resource.data.orderId)).data.customerUid == request.auth.uid;
      // Staff: full access
      allow read, create, update, delete: if hasEmail();
    }

    match /stockMovements/{movementId} {
      allow read, create, update, delete: if hasEmail();
    }

    match /settings/{settingId} {
      allow read, create, update, delete: if hasEmail();
    }

    match /deviceTokens/{tokenId} {
      allow read, create, update, delete: if hasEmail();
    }

    match /appConfig/{docId} {
      allow read, create, update, delete: if hasEmail();
    }

    match /expenses/{expenseId} {
      allow read, create, update, delete: if hasEmail();
    }

    match /activityLog/{entryId} {
      allow read, create, update, delete: if hasEmail();
    }

    match /customerNotes/{noteId} {
      allow read, create, update, delete: if hasEmail();
    }

    match /analytics/{docId} {
      allow read: if hasEmail();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
