rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Flutter staff = anonymous session that has been granted the
    // {staff: true} custom claim via /api/staff/claim (see src/lib/firebase-admin.ts
    // callers). Plain anonymous sessions (e.g. public website visitors browsing
    // the storefront) do NOT get this claim, so they are never treated as staff.
    function isStaff() {
      return request.auth != null && request.auth.token.staff == true;
    }

    // Market customers = email/Google login
    function isCustomer() {
      return request.auth != null && request.auth.token.email != null;
    }

    // Any signed-in session, including anonymous public-website visitors —
    // used only for reading the public product catalog.
    function signedIn() {
      return request.auth != null;
    }

    match /products/{productId} {
      allow read: if signedIn();
      allow create, update, delete: if isStaff();
    }

    match /productCategories/{categoryId} {
      allow read: if signedIn();
      allow create, update, delete: if isStaff();
    }

    match /orders/{orderId} {
      allow create: if isCustomer()
        && request.resource.data.customerUid == request.auth.uid;
      allow read, update: if isCustomer()
        && resource.data.customerUid == request.auth.uid;
      allow read, create, update, delete: if isStaff();
    }

    match /invoices/{invoiceId} {
      allow read: if isCustomer()
        && get(/databases/$(database)/documents/orders/$(resource.data.orderId)).data.customerUid == request.auth.uid;
      allow read, create, update, delete: if isStaff();
    }

    match /stockMovements/{movementId} {
      allow read, create, update, delete: if isStaff();
    }

    match /settings/{settingId} {
      allow read, create, update, delete: if isStaff();
    }

    match /deviceTokens/{tokenId} {
      allow read, create, update, delete: if isStaff();
    }

    match /appConfig/{docId} {
      allow read, create, update, delete: if isStaff();
    }

    match /expenses/{expenseId} {
      allow read, create, update, delete: if isStaff();
    }

    match /activityLog/{entryId} {
      allow read, create, update, delete: if isStaff();
    }

    match /customerNotes/{noteId} {
      allow read, create, update, delete: if isStaff();
    }

    match /analytics/{docId} {
      // Public aggregate view/cart-add counters, shown on the public /insights
      // page — not sensitive, so any signed-in session (including anonymous
      // public visitors) may read them. Writes only ever happen via the
      // Admin SDK from /api/analytics.
      allow read: if signedIn();
      allow write: if false;
    }

    match /marketingSubscribers/{uid} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
